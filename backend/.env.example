# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database
# Use the async SQLAlchemy driver scheme.
DATABASE_URL=postgresql+asyncpg://user:password@host:6543/postgres

# Security
JWT_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
ALGORITHM=ES256

# Admin
ADMIN_IP_ALLOWLIST=127.0.0.1

# Deployment / browser access
# Comma-separate exact frontend origins. Example:
# CORS_ORIGINS=https://medical-diary.vercel.app,https://medical-diary-git-main-yourname.vercel.app
CORS_ORIGINS=http://localhost:5174
CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1)(:\d+)?$

# For cross-origin Vercel -> Railway auth cookies, set these on Railway:
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# App
APP_NAME=Medical Diary API
DEBUG=false
SENTRY_DSN=

# SMTP is optional. If omitted, email helper may log mock email output.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@medicaldiary.com

# Resend API (Gửi email qua HTTP API, ưu tiên hơn SMTP ở production)
RESEND_API_KEY=

# Railway Cron Trigger Script Configuration (cho cron_trigger.py)
BACKEND_URL=http://localhost:8000
